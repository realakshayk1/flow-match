## 7. EGNN Implementation (full code)

Implement from scratch per Satorras et al. 2021.

```python
import torch, torch.nn as nn, torch.nn.functional as F

class EGNNLayer(nn.Module):
    """
    E(n)-Equivariant GNN layer. Satorras, Hoogeboom, Welling. ICML 2021.
    Equivariant to rotations, translations, reflections.
    """
    def __init__(self, hidden_dim, edge_dim):
        super().__init__()
        act = nn.SiLU()
        self.phi_e = nn.Sequential(          # message network (scalar)
            nn.Linear(2*hidden_dim + 1 + edge_dim, hidden_dim), act,
            nn.Linear(hidden_dim, hidden_dim), act,
        )
        self.phi_x = nn.Sequential(          # coord weight (scalar output)
            nn.Linear(hidden_dim, hidden_dim), act,
            nn.Linear(hidden_dim, 1),
        )
        self.phi_h = nn.Sequential(          # node update (scalar)
            nn.Linear(2*hidden_dim, hidden_dim), act,
            nn.Linear(hidden_dim, hidden_dim),
        )

    def forward(self, h, x, edge_index, edge_attr, fixed_mask=None):
        row, col = edge_index
        diff    = x[row] - x[col]                           # [E, 3]
        dist_sq = (diff**2).sum(-1, keepdim=True)           # [E, 1]

        m_ij = self.phi_e(torch.cat([h[row], h[col], dist_sq, edge_attr], -1))
        coord_delta = diff * self.phi_x(m_ij)               # [E, 3] equivariant

        coord_agg = torch.zeros_like(x)
        coord_agg.scatter_add_(0, col.unsqueeze(-1).expand_as(diff), coord_delta)
        if fixed_mask is not None:
            coord_agg[fixed_mask] = 0                       # pocket stays fixed

        m_agg = torch.zeros(h.size(0), m_ij.size(-1), device=h.device)
        m_agg.scatter_add_(0, col.unsqueeze(-1).expand_as(m_ij), m_ij)

        return self.phi_h(torch.cat([h, m_agg], -1)), x + coord_agg


class EGNNFlowModel(nn.Module):
    """EGNN-parameterized velocity field for flow matching."""
    def __init__(self, lig_dim, poc_dim, edge_dim, hidden=64, n_layers=4):
        super().__init__()
        self.lig_emb = nn.Linear(lig_dim + 1, hidden)       # +1 for time
        self.poc_emb = nn.Linear(poc_dim, hidden)
        self.layers  = nn.ModuleList([EGNNLayer(hidden, edge_dim) for _ in range(n_layers)])
        self.out     = nn.Linear(hidden, 3)

    def forward(self, lig_h, lig_x, poc_h, poc_x, edge_index, edge_attr, t):
        t_feat  = t.expand(lig_h.size(0), 1)
        h = torch.cat([self.lig_emb(torch.cat([lig_h, t_feat], -1)),
                        self.poc_emb(poc_h)], dim=0)
        x = torch.cat([lig_x, poc_x], dim=0)
        n_lig = lig_h.size(0)

        fixed = torch.zeros(h.size(0), dtype=torch.bool, device=h.device)
        fixed[n_lig:] = True

        for layer in self.layers:
            h, x = layer(h, x, edge_index, edge_attr, fixed)

        return self.out(h[:n_lig])                          # velocity for ligand atoms only
```

### Equivariance Unit Test — hard gate before any training
```python
def test_equivariance(model, batch, tol=1e-4):
    R = torch.linalg.qr(torch.randn(3, 3))[0]              # random rotation matrix
    v1 = model(batch.lig_h, batch.lig_x, ...)
    v2 = model(batch.lig_h, batch.lig_x @ R.T, batch.poc_h, batch.poc_x @ R.T, ...)
    err = (v2 - v1 @ R.T).abs().max()
    assert err < tol, f"Equivariance broken: {err:.2e}"
    print(f"✓ Passed (max error {err:.2e})")
```

