## 8. Training & Inference

```python
# --- Training ---
def train_epoch(model, loader, optimizer):
    model.train()
    for batch in loader:
        x_0 = torch.randn_like(batch.lig_pos)
        x_1 = batch.lig_pos
        t   = torch.rand(1)
        x_t = (1 - t) * x_0 + t * x_1
        v   = model(batch.lig_h, x_t, batch.poc_h, batch.poc_x, ...)
        loss = F.mse_loss(v, x_1 - x_0)
        loss.backward()
        nn.utils.clip_grad_norm_(model.parameters(), 1.0)
        optimizer.step(); optimizer.zero_grad()

# --- Inference (20-step Euler) ---
def generate(model, batch, n_steps=20):
    model.eval()
    x = torch.randn_like(batch.lig_pos)
    dt = 1.0 / n_steps
    for t in torch.linspace(0, 1 - dt, n_steps):
        with torch.no_grad():
            v = model(batch.lig_h, x, batch.poc_h, batch.poc_x, ..., t.unsqueeze(0))
        x = x + dt * v
    return x
```

